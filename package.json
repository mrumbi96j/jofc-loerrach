@tailwind base;
@tailwind components;
@tailwind utilities;

html {
  scroll-behavior: smooth;
}

html, body, #root {
  margin: 0;
  min-height: 100%;
}

body {
  background: #000;
  color: #fff;
  font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

* {
  box-sizing: border-box;
}

a {
  text-decoration: none;
}

button, input, select, textarea {
  font: inherit;
}
